option_settings:
  # Platform/language configuration
  aws:elasticbeanstalk:environment:process:default:
    StickinessLBCookieDuration: 86400
    HealthCheckInterval: 30
    HealthCheckTimeout: 5
    HealthyThreshold: 3
    UnhealthyThreshold: 5

  # Python platform
  aws:elasticbeanstalk:container:python:
    WSGIPath: backend/server:app
    NumProcesses: 1
    NumThreads: 15

  # Application environment variables (use EB console to override in production)
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: /var/app/current:$PYTHONPATH
    ENVIRONMENT: production

  # Auto-scaling
  aws:autoscaling:asg:
    MinSize: 1
    MaxSize: 4

  aws:autoscaling:trigger:
    MeasureName: CPUUtilization
    Statistic: Average
    Unit: Percent
    UpperThreshold: 70
    LowerThreshold: 30

  # Logging to CloudWatch
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7

files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01_app.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/eb-engine.log
      /var/log/eb-hooks.log
      /var/log/eb-activity.log
