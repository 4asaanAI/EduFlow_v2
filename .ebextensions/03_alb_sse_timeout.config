option_settings:
  # ALB idle timeout — must be >= SSE stream duration.
  # SSE endpoints: /api/chat/conversations/{id}/messages,
  #                /api/attendance/stream, /api/fees/stream
  # Default EB timeout is 60 s which kills long-running SSE streams.
  aws:elasticbeanstalk:environment:process:default:
    IdleTimeout: 300

  # Disable response buffering on the ALB so SSE chunks flush immediately.
  aws:elbv2:loadbalancer:
    IdleTimeout: 300
