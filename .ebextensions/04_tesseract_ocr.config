# Install the OCR engine so Flo can read a photographed page.
#
# UI Sweep Epic 10, Story 10.5. Abhimanyu chose on-server OCR over a paid vision
# service for printed paper: it costs nothing per page and the image never leaves
# this server, which matters when the photograph may contain a child.
#
# `tesseract` is a SYSTEM BINARY. The Python wrapper (pytesseract) installs from
# requirements.txt, but it only shells out to this program — without it, OCR does
# nothing. `tesseract-langpack-hin` is the Hindi/Devanagari data; without it
# Tesseract ERRORS on Hindi rather than degrading, which is why
# services/ocr_service.py tries "eng+hin" first and falls back to "eng".
#
# IF THIS INSTALL FAILS, NOTHING BREAKS. `ocr_available()` checks for the binary on
# PATH and the feature reports itself unavailable in plain words. That is deliberate:
# a deployment problem must not become a blank page that reads as "this form is
# empty". Check with `which tesseract` on the instance.
#
# NOTE FOR WHOEVER DEPLOYS THIS: on some Amazon Linux images tesseract lives in EPEL
# rather than the default repositories. If the packages block below finds nothing,
# enable EPEL first. The commands block is written to be safe to re-run.

packages:
  yum:
    tesseract: []
    tesseract-langpack-hin: []

commands:
  01_verify_tesseract:
    # Report the outcome into the EB logs rather than failing the deploy. The
    # application handles a missing binary gracefully, so a hard failure here would
    # take the whole release down over an optional capability.
    command: |
      if command -v tesseract >/dev/null 2>&1; then
        echo "[ocr] tesseract installed: $(tesseract --version 2>&1 | head -1)"
        echo "[ocr] languages: $(tesseract --list-langs 2>&1 | tr '\n' ' ')"
      else
        echo "[ocr] WARNING: tesseract not on PATH. Flo will report OCR as unavailable."
        echo "[ocr] If the yum packages were not found, enable EPEL and redeploy."
      fi
    ignoreErrors: true
