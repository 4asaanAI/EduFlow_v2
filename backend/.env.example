# MongoDB connection — MongoDB Atlas cloud database
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=Cluster0
DB_NAME=eduflow

# CORS — comma-separated origins (local dev or production domain)
CORS_ORIGINS=http://localhost:3000

# Environment (development | production)
ENVIRONMENT=development

# School tenant identifier — required in staging/production.
# Missing SCHOOL_ID in non-development environments causes a startup failure.
# Example: SCHOOL_ID=my-school-name
SCHOOL_ID=aaryans-joya
SCHOOL_NAME=The Aaryans

# JWT Authentication — MUST change in production (use strong random 64-char string)
JWT_SECRET=change-me-to-a-random-64-char-string-min-32-chars

# Azure OpenAI — Used for chat AI (gpt-5.3-chat)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
OPENAI_SPEND_ALERT_INR=5000

# Optional biometric dependency health check
BIOMETRIC_ENABLED=false
BIOMETRIC_HEALTH_URL=https://biometric-api.example.com/health

# Frontend URL used in password reset links
FRONTEND_URL=http://localhost:3000

# SMTP email for password reset links
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=EduFlow <mailer@example.com>

# Google Gemini — Used for image generation (certificates, ID cards)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-pro

# AWS S3 — File storage for uploads, certificates, ID cards (elastic beanstalk only)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=eduflow-uploads-prod
# Backward-compatible alias; prefer S3_BUCKET_NAME for new deployments.
S3_BUCKET=eduflow-uploads-prod

# External fee software sync
FEE_API_BASE_URL=https://fee-software.example.com/api
FEE_API_KEY=your_fee_software_api_key_here

# Twilio SMS (optional) — For SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Twilio WhatsApp Business (optional) — For WhatsApp template messages (Story 7-40)
# TWILIO_WHATSAPP_FROM must be a WhatsApp-enabled Twilio number (no whatsapp: prefix here)
TWILIO_WHATSAPP_FROM=+1234567890
# Content Template SIDs — create templates in Twilio Console > Messaging > Content Template Builder
TWILIO_WHATSAPP_FEE_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_ATTENDANCE_TEMPLATE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe — Token recharge + subscription billing (Story 7-42)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: stripe listen --forward-to localhost:8000/api/tokens/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create these in the Stripe Dashboard for INR recurring prices
STRIPE_PRICE_MONTHLY_SCHOOL_STARTER=price_...
STRIPE_PRICE_MONTHLY_SCHOOL_PRO=price_...

# Google Maps — Transport Optimisation (Story 7-46)
# Get API key from https://console.cloud.google.com/apis/credentials
# Enable: Geocoding API. Key should be server-side restricted (IP whitelist or HTTP referrer).
GOOGLE_MAPS_API_KEY=

# School onboarding — operator notifications (Story 7-44)
OPERATOR_NOTIFY_EMAIL=           # operator receives onboarding completion emails
OPERATOR_SLACK_WEBHOOK_URL=      # Slack incoming webhook URL for onboarding completion
