option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: server:app
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: /var/app/current/backend

container_commands:
  01_overwrite_procfile:
    command: "printf 'web: bash -c \"cd /var/app/current/backend && exec gunicorn -w 4 -k uvicorn.workers.UvicornWorker server:app --bind 0.0.0.0:8000 --timeout 120\"\n' > /var/app/staging/Procfile"
