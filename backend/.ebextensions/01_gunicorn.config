option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: server:app
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: /var/app/current

container_commands:
  01_overwrite_procfile:
    command: "echo 'web: gunicorn -w 4 -k uvicorn.workers.UvicornWorker server:app --bind 0.0.0.0:8000 --timeout 120' > /var/app/staging/Procfile"
