{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListTheFileBucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::eduflow-files-ap-south-1-210447603820"
    },
    {
      "Sid": "ReadWriteSchoolFiles",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::eduflow-files-ap-south-1-210447603820/*"
    }
  ]
}
